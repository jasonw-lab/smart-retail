<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youlai.boot.modules.retail.mapper.DeviceMapper">

    <resultMap id="BaseResultMap" type="com.youlai.boot.modules.retail.model.entity.Device">
        <id column="id" property="id"/>
        <result column="store_id" property="storeId"/>
        <result column="device_code" property="deviceCode"/>
        <result column="device_type" property="deviceType"/>
        <result column="device_name" property="deviceName"/>
        <result column="status" property="status"/>
        <result column="last_heartbeat" property="lastHeartbeat"/>
        <result column="error_code" property="errorCode"/>
        <result column="metadata" property="metadata"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findByStoreIdAndDeviceType" resultMap="BaseResultMap">
        SELECT * FROM retail_device
        WHERE store_id = #{storeId}
          AND device_type = #{deviceType}
          AND is_deleted = 0
        LIMIT 1
    </select>

    <select id="findByStoreId" resultMap="BaseResultMap">
        SELECT * FROM retail_device
        WHERE store_id = #{storeId}
          AND is_deleted = 0
        ORDER BY device_type, device_code
    </select>

    <!-- Heartbeat未受信デバイスを取得（沈黙監視用） -->
    <select id="findStaleDevices" resultMap="BaseResultMap">
        SELECT * FROM retail_device
        WHERE is_deleted = 0
          AND status != 'MAINTENANCE'
          AND (last_heartbeat IS NULL OR last_heartbeat &lt; #{threshold})
        ORDER BY store_id, device_type
    </select>

    <!-- ステータスでデバイス一覧を取得 -->
    <select id="findByStatus" resultMap="BaseResultMap">
        SELECT * FROM retail_device
        WHERE status = #{status}
          AND is_deleted = 0
        ORDER BY store_id, device_type
    </select>

    <!-- デバイスタイプでデバイス一覧を取得 -->
    <select id="findByDeviceType" resultMap="BaseResultMap">
        SELECT * FROM retail_device
        WHERE device_type = #{deviceType}
          AND is_deleted = 0
        ORDER BY store_id, device_code
    </select>

</mapper>
