        </mxCell>
        <mxCell id="note3" value="JWTペイロード:&#xa;userId, deptId, dataScope,&#xa;subject(username), authorities(roles),&#xa;jti, exp" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
