        <mxCell id="c1a" value="isRefreshing=false の場合のみ実行&#xa;（重複リフレッシュ防止）" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1030" y="240" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="2. POST /api/v1/auth/refresh-token&#xa;?refreshToken={refreshToken}&#xa;Authorization: &quot;no-auth&quot;" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="310" as="sourcePoint"/><mxPoint x="425" y="310" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c3" value="3. refreshToken(refreshToken)" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="360" as="sourcePoint"/><mxPoint x="660" y="360" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c4" value="4. validateRefreshToken()" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="660" y="400" as="sourcePoint"/><mxPoint x="900" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c4r" value="true" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="900" y="430" as="sourcePoint"/><mxPoint x="660" y="430" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c5" value="5. refreshToken(refreshToken)" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="660" y="470" as="sourcePoint"/><mxPoint x="900" y="470" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c5n" value="refreshTokenからAuthentication解析&#xa;新しいaccessToken生成&#xa;refreshTokenはそのまま維持" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="910" y="480" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c5r" value="AuthenticationToken&#xa;{新accessToken, 同refreshToken}" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="900" y="550" as="sourcePoint"/><mxPoint x="660" y="550" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c6r" value="AuthenticationToken" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="660" y="590" as="sourcePoint"/><mxPoint x="425" y="590" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c7r" value="6. Result&lt;AuthenticationToken&gt;" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="630" as="sourcePoint"/><mxPoint x="150" y="630" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c8n" value="7. localStorage更新&#xa;(新しいaccessToken保存)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="650" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="c9" value="8. キュー内の全リクエストを&#xa;新トークンで再実行" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="720" as="sourcePoint"/><mxPoint x="1110" y="720" as="targetPoint"/></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="seq-logout" name="4. ログアウト">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="t4" value="シーケンス図 4: ログアウトフロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- Actors -->
        <mxCell id="d_fe" value="Frontend&#xa;(Vue)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="120" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="d_ac" value="AuthController&#xa;(/api/v1/auth)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="360" y="80" width="130" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="d_as" value="AuthService&#xa;Impl" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="120" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="d_jwt" value="JwtToken&#xa;Manager" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="840" y="80" width="120" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="d_redis" value="Redis&#xa;(Blacklist)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1060" y="80" width="100" height="620" as="geometry"/>
        </mxCell>
        <!-- Flow -->
        <mxCell id="d1" value="1. DELETE /api/v1/auth/logout&#xa;Authorization: Bearer {accessToken}" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="160" y="170" as="sourcePoint"/><mxPoint x="425" y="170" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d2" value="2. logout()" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="220" as="sourcePoint"/><mxPoint x="660" y="220" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d3" value="3. SecurityUtils.getTokenFromRequest()&#xa;→ Bearer プレフィックス除去" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="240" width="230" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="d4" value="4. invalidateToken(token)" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="660" y="310" as="sourcePoint"/><mxPoint x="900" y="310" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d5" value="5. JWT解析 → jti, exp取得" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="850" y="330" width="190" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="d6" value="6. SET blacklist_token:{jti}&#xa;TTL = 残り有効期限(秒)" style="html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="900" y="390" as="sourcePoint"/><mxPoint x="1110" y="390" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d6r" value="OK" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1110" y="420" as="sourcePoint"/><mxPoint x="900" y="420" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d7" value="7. SecurityContextHolder.clearContext()" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="450" width="250" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="d8r" value="8. Result.success()" style="html=1;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="510" as="sourcePoint"/><mxPoint x="160" y="510" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d9n" value="9. localStorage クリア&#xa;(access_token, refresh_token 削除)&#xa;/login へリダイレクト" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="210" height="55" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
