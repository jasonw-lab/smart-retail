        <!-- Step 1: Heartbeat with OFFLINE terminal -->
        <mxCell id="50" value="Phase 1: Heartbeat受信（端末異常レポート含む）" style="shape=umlFrame;whiteSpace=wrap;html=1;width=350;height=18;fillColor=#fffbeb;strokeColor=#ed8936;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="30" y="230" width="940" height="190" as="geometry"/></mxCell>
        <mxCell id="20" value="1. POST /api/v1/retail/heartbeat&#xa;{storeId: &quot;STORE-001&quot;,&#xa; deviceStats: {&#xa;   paymentTerminal: {status: &quot;OFFLINE&quot;, errorCode: &quot;E103&quot;},&#xa;   printer: {status: &quot;ONLINE&quot;, paperLevel: &quot;OK&quot;},&#xa;   network: {latencyMs: 42, signalStrength: &quot;GOOD&quot;}&#xa; }}" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#ed8936;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="125" y="280" as="sourcePoint"/><mxPoint x="375" y="280" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="21" value="2. UPDATE retail_device&#xa;SET status = 'OFFLINE',&#xa;    last_heartbeat = NOW(),&#xa;    error_code = 'E103'" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#975a16;strokeWidth=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="385" y="340" as="sourcePoint"/><mxPoint x="900" y="340" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="22" value="OK" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#975a16;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="375" as="sourcePoint"/><mxPoint x="385" y="375" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="23" value="3. 200 OK" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#ed8936;strokeWidth=2;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="375" y="400" as="sourcePoint"/><mxPoint x="125" y="400" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Step 2: Monitor detects OFFLINE status -->
        <mxCell id="51" value="Phase 2: 沈黙監視 — デバイス状態チェック (@Scheduled)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=380;height=18;fillColor=#fff5f5;strokeColor=#c53030;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="490" y="440" width="490" height="310" as="geometry"/></mxCell>
        <mxCell id="30" value="4. 定期チェック発火" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#fc8181;strokeWidth=2;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="485" as="sourcePoint"/><mxPoint x="900" y="485" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="31" value="5. SELECT device&#xa;WHERE status IN ('OFFLINE','ERROR')&#xa;AND device_type = 'PAYMENT_TERMINAL'" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#fc8181;strokeWidth=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="530" as="sourcePoint"/><mxPoint x="900" y="530" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="32" value="該当デバイス（POS: OFFLINE, E103）" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#fc8181;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="570" as="sourcePoint"/><mxPoint x="640" y="570" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="33" value="6. 重複チェック&#xa;findActiveAlert(storeId, deviceId, PAYMENT_TERMINAL_DOWN)" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#fc8181;strokeWidth=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="610" as="sourcePoint"/><mxPoint x="900" y="610" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="34" value="null（新規生成OK）" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#fc8181;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="645" as="sourcePoint"/><mxPoint x="640" y="645" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="35" value="7. INSERT retail_alert&#xa;(type=PAYMENT_TERMINAL_DOWN,&#xa; priority=P1, device_id=DEV-TK-POS-01, status=NEW)" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#c53030;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="690" as="sourcePoint"/><mxPoint x="900" y="690" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="36" value="OK" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#c53030;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="725" as="sourcePoint"/><mxPoint x="640" y="725" as="targetPoint"/></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="seq-recovery" name="5. 障害回復 自動クローズ">
    <mxGraphModel dx="1300" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="障害回復 → アラート自動クローズ シーケンス" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#276749;" vertex="1" parent="1"><mxGeometry x="300" y="15" width="450" height="30" as="geometry"/></mxCell>
        <mxCell id="10" value="PowerJob Worker&#xa;(DeviceRecoveryJob)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ed8936;fontColor=#ffffff;strokeColor=#c05621;size=40;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="170" height="750" as="geometry"/></mxCell>
        <mxCell id="11" value="Backend&#xa;(HeartbeatController)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ecc94b;fontColor=#1a202c;strokeColor=#d69e2e;size=40;" vertex="1" parent="1"><mxGeometry x="300" y="70" width="160" height="750" as="geometry"/></mxCell>
        <mxCell id="12" value="Backend&#xa;(AlertAutoCloseJob)&#xa;@Scheduled" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#805ad5;fontColor=#ffffff;strokeColor=#6b46c1;size=40;" vertex="1" parent="1"><mxGeometry x="560" y="70" width="170" height="750" as="geometry"/></mxCell>
        <mxCell id="13" value="MySQL&#xa;(device / alert)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e2e8f0;fontColor=#1a202c;strokeColor=#a0aec0;size=40;" vertex="1" parent="1"><mxGeometry x="840" y="70" width="130" height="750" as="geometry"/></mxCell>
        <mxCell id="14" value="Frontend&#xa;(A-01)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#3182ce;fontColor=#ffffff;strokeColor=#2b6cb0;size=40;" vertex="1" parent="1"><mxGeometry x="1100" y="70" width="100" height="750" as="geometry"/></mxCell>
        <!-- Phase 1: Recovery -->
        <mxCell id="50" value="Phase 1: 障害回復 — 正常Heartbeat再開" style="shape=umlFrame;whiteSpace=wrap;html=1;width=300;height=18;fillColor=#f0fff4;strokeColor=#48bb78;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="30" y="140" width="940" height="140" as="geometry"/></mxCell>
        <mxCell id="20" value="1. POST /heartbeat (正常復帰)&#xa;{deviceStats.paymentTerminal.status: &quot;ONLINE&quot;}" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#48bb78;strokeWidth=2;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="125" y="185" as="sourcePoint"/><mxPoint x="375" y="185" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="21" value="2. UPDATE device SET status='ONLINE'" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#975a16;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="385" y="225" as="sourcePoint"/><mxPoint x="900" y="225" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="22" value="3. 200 OK" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#48bb78;strokeWidth=2;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="375" y="260" as="sourcePoint"/><mxPoint x="125" y="260" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Phase 2: Auto resolve -->
        <mxCell id="51" value="Phase 2: 自動クローズチェック (@Scheduled 1時間毎)" style="shape=umlFrame;whiteSpace=wrap;html=1;width=370;height=18;fillColor=#faf5ff;strokeColor=#805ad5;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="500" y="310" width="480" height="220" as="geometry"/></mxCell>
        <mxCell id="30" value="4. checkAlertResolution() 発火" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#805ad5;strokeWidth=2;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="355" as="sourcePoint"/><mxPoint x="900" y="355" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="31" value="5. SELECT alert WHERE status='IN_PROGRESS'" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#805ad5;strokeWidth=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="395" as="sourcePoint"/><mxPoint x="900" y="395" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="32" value="対象アラート返却" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#805ad5;strokeWidth=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="425" as="sourcePoint"/><mxPoint x="645" y="425" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="33" value="6. 条件解消確認 → device.status == ONLINE" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#805ad5;strokeWidth=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="460" as="sourcePoint"/><mxPoint x="900" y="460" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="34" value="7. UPDATE alert&#xa;SET status='RESOLVED', resolved_at=NOW()" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#48bb78;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="500" as="sourcePoint"/><mxPoint x="900" y="500" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Phase 3: Auto close after 24h -->
        <mxCell id="98" value="⏳ 24時間経過" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=3;fontColor=#805ad5;" vertex="1" parent="1"><mxGeometry x="400" y="555" width="160" height="25" as="geometry"/></mxCell>
        <mxCell id="52" value="Phase 3: 24時間後の自動CLOSED" style="shape=umlFrame;whiteSpace=wrap;html=1;width=250;height=18;fillColor=#faf5ff;strokeColor=#805ad5;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="500" y="600" width="480" height="100" as="geometry"/></mxCell>
        <mxCell id="40" value="8. autoCloseResolvedAlerts()&#xa;WHERE resolved_at &lt; NOW() - 24h" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#805ad5;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="640" as="sourcePoint"/><mxPoint x="900" y="640" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="41" value="9. UPDATE alert SET status='CLOSED', closed_at=NOW()" style="html=1;verticalAlign=bottom;endArrow=block;strokeColor=#276749;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="680" as="sourcePoint"/><mxPoint x="900" y="680" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Frontend -->
        <mxCell id="45" value="10. アラート状態更新表示&#xa;IN_PROGRESS → RESOLVED → CLOSED" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#276749;strokeWidth=2;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="900" y="760" as="sourcePoint"/><mxPoint x="1145" y="760" as="targetPoint"/></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
